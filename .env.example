# Application
PROJECT_NAME=Amenly
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=100
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (Supabase PostgreSQL)
POSTGRES_SERVER=your-project.pooler.supabase.com
POSTGRES_USER=postgres.xxxxx
POSTGRES_PASSWORD=your-database-password
POSTGRES_DB=postgres
DATABASE_URL=postgresql+psycopg://postgres.xxxxx:your-password@your-project.pooler.supabase.com:6543/postgres

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Redis (Token Management & Caching)
REDIS_URL=redis://redis:6379/0

# Qdrant (Vector Database for AI)
QDRANT_URL=http://qdrant:6333

# Ollama (AI Model Server)
OLLAMA_URL=http://ollama:11434
AI_MODEL=llama3
EMBEDDING_MODEL=nomic-embed-text

# CORS (Comma-separated origins)
BACKEND_CORS_ORIGINS=["http://localhost","http://localhost:3000","http://localhost:8000"]

